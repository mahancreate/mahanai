# import mahanai dev kit from dev kit
import mahanai from maidevkit

# add a reciver to add the command /compact
add command("/compact",if fail create(status = 1)){
	# iimporting provider features from pvd
	import provider-features from pvd
	# using claude code's /compact for mine
	pvd(claude-code)[
		use-claude-cmd("/compact")
	]
}

# end with sucses
end-script(status)

